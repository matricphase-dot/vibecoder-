# VibeCoder Environment Variables
# Enterprise Mode (true = zero outbound, local only)
ENTERPRISE_MODE=false

# Model API Keys (optional, for cloud providers)
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Audit DB path (default: workspace/.audit/audit.db)
AUDIT_DB_PATH=workspace/.audit/audit.db
