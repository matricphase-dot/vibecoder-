@app.post("/api/predict-intent")
async def predict_intent(partial: str):
    # Use AI to predict full prompt
    try:
        import ollama
        response = ollama.chat(model="tinyllama", messages=[{
            "role": "user",
            "content": f"Complete this user prompt into a full software request: '{partial}'. Return only the completed sentence."
        }])
        full = response['message']['content'].strip()
        return {"full_prompt": full}
    except:
        return {"full_prompt": partial}
# Flow Memory: store session goal and track completed files
session_goals = {}  # workspace_id -> {"goal": str, "planned_files": list, "completed_files": list, "timestamp": str}

@app.post("/api/session/goal")
async def set_session_goal(workspace_id: int, goal: str, planned_files: list = []):
    session_goals[workspace_id] = {
        "goal": goal,
        "planned_files": planned_files,
        "completed_files": [],
        "timestamp": datetime.now().isoformat()
    }
    return {"status": "ok"}

@app.post("/api/session/complete-file")
async def mark_file_complete(workspace_id: int, file_path: str):
    if workspace_id in session_goals:
        if file_path not in session_goals[workspace_id]["completed_files"]:
            session_goals[workspace_id]["completed_files"].append(file_path)
    return {"status": "ok"}

@app.get("/api/session/status/{workspace_id}")
async def get_session_status(workspace_id: int):
    if workspace_id not in session_goals:
        return {"has_goal": False}
    goal = session_goals[workspace_id]
    progress = len(goal["completed_files"]) / max(len(goal["planned_files"]), 1)
    return {
        "has_goal": True,
        "goal": goal["goal"],
        "planned_files": goal["planned_files"],
        "completed_files": goal["completed_files"],
        "progress": progress,
        "timestamp": goal["timestamp"]
    }
@app.post("/api/silent-fix")
async def silent_fix(files: dict):
    """Analyze files and return suggested fixes (non‑destructive)."""
    fixes = {}
    for path, content in files.items():
        original = content
        fixed = content
        
        # Simple regex fixes (fast, no AI)
        # 1. Add missing semicolons at line ends (basic)
        import re
        fixed = re.sub(r'(?<![;{}])\s*$', ';', fixed, flags=re.MULTILINE)
        # 2. Remove console.log statements (optional – can be configurable)
        fixed = re.sub(r'console\.log\(.*?\);?\s*', '', fixed)
        # 3. Fix common JS errors: missing closing brackets, etc. (AI for complex cases)
        
        if fixed != original:
            fixes[path] = fixed
    
    # For complex fixes, call AI (if needed)
    if not fixes and len(str(files)) > 200:
        # Use Ollama to suggest improvements
        try:
            import ollama
            prompt = f"Suggest minimal improvements for this code (syntax, best practices):\n{list(files.values())[0][:1000]}"
            response = ollama.chat(model="tinyllama", messages=[{"role": "user", "content": prompt}])
            # Parse response (simplified)
            fixes["_ai_suggestion"] = response['message']['content']
        except:
            pass
    
    return {"fixes": fixes}
from collections import deque
from datetime import datetime, timedelta

# Frustration tracking per workspace
frustration_state = {}  # workspace_id -> {score, events: deque, last_help_offered}

class FrustrationEvent:
    def __init__(self, type, timestamp=None):
        self.type = type  # "rapid_edit", "repeated_error", "repeated_generation", "preview_error"
        self.timestamp = timestamp or datetime.now()

@app.post("/api/frustration/event")
async def report_frustration_event(workspace_id: int, event_type: str):
    now = datetime.now()
    if workspace_id not in frustration_state:
        frustration_state[workspace_id] = {
            "score": 0,
            "events": deque(maxlen=20),
            "last_help_offered": None,
            "last_event_time": now
        }
    state = frustration_state[workspace_id]
    state["events"].append(FrustrationEvent(event_type, now))
    state["last_event_time"] = now
    
    # Update score based on event type and recency
    weights = {
        "rapid_edit": 10,
        "repeated_error": 20,
        "repeated_generation": 15,
        "preview_error": 25
    }
    # Decay old events (> 2 minutes)
    cutoff = now - timedelta(minutes=2)
    while state["events"] and state["events"][0].timestamp < cutoff:
        old = state["events"].popleft()
        state["score"] -= weights.get(old.type, 10)
    state["score"] = max(0, state["score"] + weights.get(event_type, 10))
    
    # Determine if help should be offered
    should_offer_help = False
    help_message = None
    if state["score"] > 40 and (state["last_help_offered"] is None or (now - state["last_help_offered"]) > timedelta(minutes=1)):
        should_offer_help = True
        if event_type == "rapid_edit":
            help_message = "You're editing quickly. Want me to suggest a different approach or use a template?"
        elif event_type == "repeated_error":
            help_message = "I see the same error keeps appearing. Shall I debug it for you?"
        elif event_type == "repeated_generation":
            help_message = "You've asked for similar generation multiple times. Maybe we should adjust the plan?"
        else:
            help_message = "You seem stuck. Need a hand? Try describing what you want more simply."
        state["last_help_offered"] = now
        # Reduce score after offering help to avoid spam
        state["score"] = max(0, state["score"] - 30)
    
    return {"frustration_score": state["score"], "offer_help": should_offer_help, "message": help_message}

@app.get("/api/frustration/status/{workspace_id}")
async def get_frustration_status(workspace_id: int):
    if workspace_id not in frustration_state:
        return {"frustration_score": 0}
    return {"frustration_score": frustration_state[workspace_id]["score"]}
import json
from pathlib import Path

PREFERENCES_DIR = Path("./user_preferences")
PREFERENCES_DIR.mkdir(exist_ok=True)

def get_pref_path(workspace_id: int) -> Path:
    return PREFERENCES_DIR / f"workspace_{workspace_id}.json"

@app.post("/api/preferences/save")
async def save_preferences(workspace_id: int, preferences: dict):
    path = get_pref_path(workspace_id)
    with open(path, "w") as f:
        json.dump(preferences, f)
    return {"status": "ok"}

@app.get("/api/preferences/load/{workspace_id}")
async def load_preferences(workspace_id: int):
    path = get_pref_path(workspace_id)
    if path.exists():
        with open(path, "r") as f:
            return json.load(f)
    return {}  # empty defaults
import re
import json
from typing import List, Dict

@app.post("/api/predict-failures")
async def predict_failures(files: dict):
    warnings = []
    
    for path, content in files.items():
        if not content:
            continue
        
        # 1. Check for missing API keys in fetch URLs
        api_key_pattern = r'fetch\(["\'](https?://[^"\']*?)(?:\?|&)(?:api[_-]?key|token|apikey)=["\']?[^"\']*["\']?\)'
        if re.search(api_key_pattern, content, re.IGNORECASE):
            warnings.append({
                "file": path,
                "severity": "high",
                "message": "Possible hardcoded API key in fetch URL. Consider using environment variables."
            })
        
        # 2. Look for fetch calls without .catch() or async/await error handling
        fetch_calls = re.findall(r'fetch\([^;]+\)(?!\.catch)', content)
        if fetch_calls and 'async' not in content and '.catch' not in content:
            warnings.append({
                "file": path,
                "severity": "medium",
                "message": f"Fetch calls without error handling. Add .catch() or use try/catch."
            })
        
        # 3. Infinite loop detection (simple)
        if re.search(r'while\s*\(\s*true\s*\)', content) or re.search(r'for\s*\(;;\)', content):
            warnings.append({
                "file": path,
                "severity": "high",
                "message": "Infinite loop detected (while(true) or for(;;)). This will freeze the browser."
            })
        
        # 4. Undefined variable detection (basic – looking for common misspellings)
        # Check for variables that might be undefined (simple regex)
        var_uses = re.findall(r'\b([a-zA-Z_][a-zA-Z0-9_]*)\b', content)
        var_defs = set(re.findall(r'(?:var|let|const)\s+([a-zA-Z_][a-zA-Z0-9_]*)\s*=', content))
        var_defs.update(re.findall(r'function\s+([a-zA-Z_][a-zA-Z0-9_]*)\s*\(', content))
        var_defs.update(re.findall(r'([a-zA-Z_][a-zA-Z0-9_]*)\s*=\s*(?:function|\(|async)', content))
        undefined_vars = [v for v in var_uses if v not in var_defs and v not in ['window','document','console','alert','fetch','localStorage','sessionStorage','setTimeout','setInterval','clearTimeout','clearInterval','Promise','JSON','Math','undefined','null','true','false','this','arguments']]
        if undefined_vars:
            warnings.append({
                "file": path,
                "severity": "medium",
                "message": f"Possible undefined variables: {', '.join(set(undefined_vars[:5]))}"
            })
        
        # 5. Missing event listener for common IDs (e.g., button click)
        # Look for getElementById('someId') but no corresponding addEventListener for that ID
        ids_queried = re.findall(r'getElementById\(["\']([^"\']+)["\']\)', content)
        if ids_queried:
            for id_name in ids_queried:
                if not re.search(f'addEventListener.*{id_name}', content) and not re.search(f'onclick\\s*=\\s*["\'].*{id_name}', content):
                    warnings.append({
                        "file": path,
                        "severity": "low",
                        "message": f"Element with id '{id_name}' is queried but no event listener attached. Might be unused."
                    })
        
        # 6. Async function without await (for fetch/axios)
        if 'async' in content and 'await' not in content and ('fetch' in content or 'axios' in content):
            warnings.append({
                "file": path,
                "severity": "medium",
                "message": "Async function contains fetch/axios but no await. The promise will not resolve correctly."
            })
    
    # Optional: Use AI for more sophisticated predictions (if no warnings found)
    if not warnings and len(str(files)) < 3000:
        try:
            import ollama
            prompt = f"Analyze this code for potential runtime errors, security issues, or bad practices. Return a JSON list of warnings with 'file', 'severity' (high/medium/low), and 'message'. Code:\n{json.dumps(files, indent=2)[:2000]}"
            response = ollama.chat(model="tinyllama", messages=[{"role": "user", "content": prompt}])
            # Attempt to parse AI response
            ai_content = response['message']['content']
            import json
            start = ai_content.find('[')
            end = ai_content.rfind(']') + 1
            if start != -1:
                ai_warnings = json.loads(ai_content[start:end])
                warnings.extend(ai_warnings)
        except Exception as e:
            print(f"AI failure prediction error: {e}")
    
    return {"warnings": warnings}
from pydantic import BaseModel
from typing import List, Dict, Any
import ollama
import json
import re

class FixRequest(BaseModel):
    error: str
    files: Dict[str, str]
    context: str = ""  # optional additional description

@app.post("/api/optimize-fix")
async def optimize_fix(req: FixRequest):
    """Return three fix strategies: fast, safe, long‑term."""
    # Prepare a summary of the code (first 2000 chars of the relevant file)
    # For simplicity, take the first file or the one that seems most relevant.
    relevant_file = list(req.files.keys())[0] if req.files else "unknown"
    code_snippet = req.files.get(relevant_file, "")[:2000]
    
    prompt = f"""You are an expert software engineer. Given the following error and code, provide three different fix strategies:

Error: {req.error}
File: {relevant_file}
Code snippet:

Return a JSON object with three keys: "fast", "safe", "longterm". Each key must be an object containing:
- "description": short explanation of the fix (max 100 chars)
- "estimated_time": integer in minutes
- "patch": the exact code replacement for the file (full file content after fix)

Make sure the patch is complete and ready to replace the existing file. Use markdown only if necessary.

Example:
{{
  "fast": {{"description": "Add null check", "estimated_time": 2, "patch": "if (!obj) return; ..."}},
  "safe": {{"description": "Wrap in try-catch", "estimated_time": 5, "patch": "try {{ ... }} catch(e) {{ console.error(e); }}"}},
  "longterm": {{"description": "Rewrite with async/await and error handling", "estimated_time": 15, "patch": "..."}}
}}
"""
    try:
        response = ollama.chat(model="mistral", messages=[{"role": "user", "content": prompt}], stream=False)
        content = response['message']['content']
        # Extract JSON
        match = re.search(r'\{.*"fast".*"longterm".*\}', content, re.DOTALL)
        if match:
            fixes = json.loads(match.group())
            # Ensure each fix has required fields
            for key in ["fast", "safe", "longterm"]:
                if key not in fixes:
                    fixes[key] = {"description": "No suggestion", "estimated_time": 0, "patch": ""}
            return fixes
        else:
            # Fallback
            return {
                "fast": {"description": "Add error handling", "estimated_time": 2, "patch": ""},
                "safe": {"description": "Use try-catch", "estimated_time": 5, "patch": ""},
                "longterm": {"description": "Refactor with proper error boundaries", "estimated_time": 15, "patch": ""}
            }
    except Exception as e:
        return {
            "fast": {"description": f"AI error: {str(e)}", "estimated_time": 0, "patch": ""},
            "safe": {"description": "Please try again", "estimated_time": 0, "patch": ""},
            "longterm": {"description": "Contact support", "estimated_time": 0, "patch": ""}
        }
import asyncio
import subprocess
import os
import sys
from fastapi import WebSocket, WebSocketDisconnect

@app.websocket("/ws/terminal/{workspace_id}")
async def terminal_endpoint(websocket: WebSocket, workspace_id: int):
    await websocket.accept()  # Connection accepted
    workspace_path = get_workspace_path(workspace_id)
    workspace_path.mkdir(parents=True, exist_ok=True)
    
    # Choose shell based on OS
    if sys.platform == "win32":
        shell_cmd = "cmd.exe"
    else:
        shell_cmd = "/bin/bash"
    
    proc = await asyncio.create_subprocess_shell(
        shell_cmd,
        stdin=subprocess.PIPE,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        cwd=str(workspace_path)
    )
    
    async def read_output(stream, ws):
        while True:
            line = await stream.readline()
            if not line:
                break
            await ws.send_text(line.decode('utf-8', errors='ignore'))
    
    out_task = asyncio.create_task(read_output(proc.stdout, websocket))
    err_task = asyncio.create_task(read_output(proc.stderr, websocket))
    
    try:
        while True:
            data = await websocket.receive_text()
            if data == "__END__":
                break
            proc.stdin.write((data + "\n").encode())
            await proc.stdin.drain()
    except WebSocketDisconnect:
        pass
    finally:
        proc.terminate()
        out_task.cancel()
        err_task.cancel()
from pydantic import BaseModel

class SuggestRequest(BaseModel):
    file_path: str
    content: str
    cursor_position: int
    language: str

@app.post("/api/suggest")
async def get_inline_suggestion(req: SuggestRequest):
    before = req.content[max(0, req.cursor_position-100):req.cursor_position]
    after = req.content[req.cursor_position:req.cursor_position+50]
    prompt = f"""You are a code completion AI. Based on the context, suggest a short completion (max 30 characters) that the user is likely to type next.

Language: {req.language}
Code before cursor:
Code after cursor:
Return ONLY the suggested completion text, no explanation."""
    try:
        import ollama
        response = ollama.chat(model="tinyllama", messages=[{"role": "user", "content": prompt}])
        suggestion = response['message']['content'].strip()
        return {"suggestion": suggestion}
    except:
        return {"suggestion": ""}
