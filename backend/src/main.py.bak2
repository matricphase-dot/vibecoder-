# Helper: detect language from file extension
def detect_language(file_path):
    if file_path.endswith('.js') or file_path.endswith('.jsx'):
        return 'javascript'
    elif file_path.endswith('.py'):
        return 'python'
    elif file_path.endswith('.html'):
        return 'html'
    else:
        return 'unknown'

# Generate tests using AI
# ========== UNIT TEST GENERATION (SIMPLIFIED) ==========
async def generate_tests(file_path, code, language):
    # Use a simple prompt without triple quotes inside f-string
    prompt = "You are an expert test writer. Write comprehensive unit tests for the following code.\n\nLanguage: " + language + "\nFile: " + file_path + "\nCode:\n```\n" + code + "\n```\n\nReturn ONLY the test code as plain text. Use appropriate framework: Jest for JavaScript, pytest for Python, basic DOM checks for HTML."
    try:
        response = ollama.chat(model="mistral", messages=[{"role": "user", "content": prompt}])
        test_code = response['message']['content'].strip()
        test_code = re.sub(r'```\w*\n?', '', test_code)
        return test_code
    except Exception as e:
        return f"// Error generating tests: {str(e)}"
    except Exception as e:
        return f"// Error generating tests: {str(e)}"

def run_tests(file_path, code, test_code, language):
    # Simplified: return dummy result for now (to avoid dependency issues)
    return True, "Tests passed (simulated)", ""

@app.post("/api/generate-tests")
async def generate_tests_endpoint(req: TestRequest):
    results = {}
    for file_path, code in req.files.items():
        lang = detect_language(file_path)
        if lang == 'unknown':
            results[file_path] = {"error": "Unsupported file type"}
            continue
        test_code = await generate_tests(file_path, code, lang)
        passed, stdout, stderr = run_tests(file_path, code, test_code, lang)
        results[file_path] = {
            "test_code": test_code,
            "passed": passed,
            "stdout": stdout,
            "stderr": stderr
        }
    return results

