@app.get("/api/templates")
async def list_templates():
    return {name: {"name": info["name"], "description": info["description"]} for name, info in TEMPLATES.items()}

@app.post("/api/templates/{template_name}")
async def apply_template(template_name: str, workspace_id: int):
    if template_name not in TEMPLATES:
        raise HTTPException(status_code=404, detail="Template not found")
    if workspace_id not in workspace_states:
        workspace_states[workspace_id] = {'files': {}, 'requirements': {}}
    workspace_states[workspace_id]['files'] = TEMPLATES[template_name]['files'].copy()
    return {"status": "applied", "files": list(workspace_states[workspace_id]['files'].keys())}

@app.get("/api/workspace/{workspace_id}/files")
async def get_workspace_files(workspace_id: int):
    if workspace_id not in workspace_states:
        return {}
    return workspace_states[workspace_id].get('files', {})

# ---------- Git, Deploy, Export, LLM (stubs to avoid missing imports) ----------
import git
PROJECTS_DIR = Path("./generated_projects")
PROJECTS_DIR.mkdir(exist_ok=True)
def get_workspace_path(workspace_id: int) -> Path:
    return PROJECTS_DIR / str(workspace_id)

class CommitRequest(BaseModel):
    workspace_id: int
    message: str

@app.post("/api/commit")
async def commit_generation(req: CommitRequest):
    if req.workspace_id not in workspace_states:
        raise HTTPException(status_code=404, detail="Workspace not found")
    files = workspace_states[req.workspace_id].get('files', {})
    if not files:
        raise HTTPException(status_code=400, detail="No files")
    repo_path = get_workspace_path(req.workspace_id)
    repo_path.mkdir(parents=True, exist_ok=True)
    for path, content in files.items():
        (repo_path / path).parent.mkdir(parents=True, exist_ok=True)
        (repo_path / path).write_text(content, encoding='utf-8')
    repo = git.Repo.init(repo_path)
    repo.index.add('*')
    commit = repo.index.commit(req.message)
    return {"status": "committed", "commit": commit.hexsha[:8], "files": len(files)}

@app.get("/api/branches/{workspace_id}")
async def list_branches(workspace_id: int):
    repo_path = get_workspace_path(workspace_id)
    if not repo_path.exists():
        return {"branches": []}
    repo = git.Repo(repo_path)
    return {"branches": [b.name for b in repo.branches]}

@app.post("/api/switch-branch/{workspace_id}")
async def switch_branch(workspace_id: int, branch_name: str):
    repo_path = get_workspace_path(workspace_id)
    if not repo_path.exists():
        raise HTTPException(status_code=404, detail="No repo")
    repo = git.Repo(repo_path)
    if branch_name in [b.name for b in repo.branches]:
        repo.git.checkout(branch_name)
    else:
        repo.git.checkout('-b', branch_name)
    files = {}
    for file_path in repo_path.glob("**/*"):
        if file_path.is_file():
            rel = file_path.relative_to(repo_path)
            files[str(rel)] = file_path.read_text(encoding='utf-8')
    workspace_states[workspace_id]['files'] = files
    return {"status": "switched", "branch": branch_name, "files": len(files)}

class DeployRequest(BaseModel):
    workspace_id: int
    vercel_token: str = ""

@app.post("/api/deploy-vercel")
async def deploy_to_vercel(req: DeployRequest):
    repo_path = get_workspace_path(req.workspace_id)
    if not repo_path.exists():
        raise HTTPException(status_code=404, detail="No project")
    vercel_json = repo_path / "vercel.json"
    if not vercel_json.exists():
        vercel_json.write_text('{"version":2,"builds":[{"src":"*.html","use":"@vercel/static"}],"routes":[{"src":"/(.*)","dest":"/$1"}]}')
    import subprocess, re
    env = os.environ.copy()
    if req.vercel_token:
        env["VERCEL_TOKEN"] = req.vercel_token
    result = subprocess.run(["npx", "vercel", "--prod", "--yes", "--cwd", str(repo_path)], capture_output=True, text=True, env=env)
    if result.returncode != 0:
        raise HTTPException(status_code=500, detail=result.stderr)
    match = re.search(r'https://[-\w]+\.vercel\.app', result.stdout)
    url = match.group(0) if match else "deployed"
    return {"status": "deployed", "url": url}

@app.get("/api/export/{workspace_id}")
async def export_workspace(workspace_id: int):
    if workspace_id not in workspace_states:
        raise HTTPException(status_code=404, detail="Workspace not found")
    files = workspace_states[workspace_id].get('files', {})
    if not files:
        raise HTTPException(status_code=400, detail="No files")
    zip_buffer = io.BytesIO()
    with zipfile.ZipFile(zip_buffer, 'w', zipfile.ZIP_DEFLATED) as zip_file:
        for path, content in files.items():
            zip_file.writestr(path, content)
    zip_buffer.seek(0)
    return StreamingResponse(zip_buffer, media_type="application/zip", headers={"Content-Disposition": f"attachment; filename=vibecoder-workspace-{workspace_id}.zip"})

class LLMConfig(BaseModel):
    provider: str
    api_key: str = ""
    model: str = "gpt-3.5-turbo"
    base_url: str = ""

llm_configs = {}

@app.post("/api/llm/config")
async def set_llm_config(workspace_id: int, config: LLMConfig):
    llm_configs[workspace_id] = config
    return {"status": "ok"}

@app.post("/api/llm/chat")
async def llm_chat(workspace_id: int, messages: List[dict]):
    config = llm_configs.get(workspace_id)
    if not config or config.provider == "ollama":
        import ollama
        response = ollama.chat(model=config.model if config else "tinyllama", messages=messages)
        return {"content": response['message']['content']}
    elif config.provider == "openai":
        import httpx
        async with httpx.AsyncClient() as client:
            resp = await client.post("https://api.openai.com/v1/chat/completions", headers={"Authorization": f"Bearer {config.api_key}"}, json={"model": config.model, "messages": messages})
            return resp.json()["choices"][0]["message"]
    else:
        return {"content": "Provider not supported"}
from pydantic import BaseModel
import ollama

class DebugRequest(BaseModel):
    workspace_id: int
    error: str
    files: dict

@app.post("/api/debug")
async def debug_error(req: DebugRequest):
    # Use AI to analyze error and suggest fix
    prompt = f"""You are a debugging expert. The following error occurred in a web app:
Error: {req.error}
Code files: {list(req.files.keys())}

Provide a fix in JSON format: {{"description": "what to change", "file": "path", "patch": "exact code replacement or diff"}}"""
    try:
        response = ollama.chat(model="tinyllama", messages=[{"role": "user", "content": prompt}])
        import json
        # Attempt to parse JSON from response
        content = response['message']['content']
        start = content.find('{')
        end = content.rfind('}') + 1
        if start != -1:
            fix = json.loads(content[start:end])
        else:
            fix = {"description": "No fix generated", "file": "", "patch": ""}
        return {"fix": fix}
    except Exception as e:
        return {"fix": {"description": f"AI error: {str(e)}", "file": "", "patch": ""}}
from collections import deque
from datetime import datetime

# Store prompt history per workspace
prompt_history = {}

@app.post("/api/detect-loop")
async def detect_loop(workspace_id: int, prompt: str):
    if workspace_id not in prompt_history:
        prompt_history[workspace_id] = deque(maxlen=5)
    history = prompt_history[workspace_id]
    history.append(prompt)
    
    # Check for repeats (exact match within last 3 prompts)
    list_history = list(history)
    if len(list_history) >= 3 and len(set(list_history[-3:])) == 1:
        return {"loop_detected": True, "message": "You've asked the same thing 3 times. Would you like to try a different approach or refine your request?"}
    
    # Check for similarity (simple word overlap)
    if len(list_history) >= 2:
        prev = list_history[-2].lower().split()
        curr = prompt.lower().split()
        overlap = len(set(prev) & set(curr)) / max(len(prev), len(curr))
        if overlap > 0.8:
            return {"loop_detected": True, "message": "This is very similar to your last prompt. Need help rephrasing?"}
    
    return {"loop_detected": False}
