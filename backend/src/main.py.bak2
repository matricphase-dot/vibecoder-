# Import generation module
from src.generation import run_generation, workspace_states

app = FastAPI()

# CORS
app.add_middleware(
    CORSMiddleware,
    allow_origins=["http://localhost:5173", "http://127.0.0.1:5173"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# ---------- WebSocket ----------
@app.websocket("/ws/{workspace_id}")
async def websocket_endpoint(websocket: WebSocket, workspace_id: int):
    await websocket.accept()  # Connection accepted
    print(f"✅ WebSocket connected: {workspace_id}")
    try:
        while True:
            data = await websocket.receive_text()
            message = json.loads(data)
            msg_type = message.get("type")
            if msg_type == "generate":
                prompt = message.get("prompt")
                asyncio.create_task(run_generation(prompt, workspace_id, websocket))
            elif msg_type == "select_plan":
                plan_index = message.get("plan_index")
                if workspace_id in workspace_states:
                    workspace_states[workspace_id]['selected_plan_index'] = plan_index
                    await websocket.send_text(json.dumps({"type": "log", "message": f"Plan {plan_index} selected"}))
                else:
                    await websocket.send_text(json.dumps({"type": "error", "message": "No active generation"}))
            elif msg_type == "ping":
                await websocket.send_text(json.dumps({"type": "pong"}))
    except WebSocketDisconnect:
        print(f"❌ Disconnected: {workspace_id}")

