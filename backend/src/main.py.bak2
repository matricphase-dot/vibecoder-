@app.post("/api/generate-docs")
async def generate_docs(request: dict):
    files = request.get("files", {})
    if not files:
        return {"error": "No files provided"}
    
    project_summary = ""
    for path, content in files.items():
        project_summary += "## " + path + "\n```\n" + content[:300] + "\n```\n\n"
    
    # README generation
    prompt_readme = "You are a technical writer. Create a README.md for this project.\n\nProject files summary:\n" + project_summary + "\nReturn ONLY the markdown content, starting with '# Project Title'. Include: Description, Features, Installation, Usage, File structure, Technologies used."
    try:
        import ollama
        import re
        response = ollama.chat(model="mistral", messages=[{"role": "user", "content": prompt_readme}])
        readme = response['message']['content'].strip()
        readme = re.sub(r'```markdown\n?', '', readme)
        readme = re.sub(r'```\n?', '', readme)
    except Exception as e:
        readme = "# Project\n\nError generating README: " + str(e)
    
    # Diagram generation
    prompt_diagram = "Generate a Mermaid.js architecture diagram for this project.\n\nProject files:\n" + project_summary + "\nReturn ONLY the mermaid code, starting with '```mermaid' and ending with '```'."
    try:
        response = ollama.chat(model="mistral", messages=[{"role": "user", "content": prompt_diagram}])
        diagram = response['message']['content'].strip()
        if not diagram.startswith('```mermaid'):
            diagram = "```mermaid\n" + diagram + "\n```"
    except Exception as e:
        diagram = "```mermaid\ngraph TD\n    A[Error] --> B[" + str(e) + "]\n```"
    
    return {"docs": readme, "diagram": diagram}

import asyncio
import subprocess
import sys
import os
import shlex
from fastapi import WebSocket, WebSocketDisconnect

@app.websocket("/ws/terminal/{workspace_id}")
async def terminal_endpoint(websocket: WebSocket, workspace_id: int):
    await websocket.accept()  # Connection accepted
    workspace_path = get_workspace_path(workspace_id)
    workspace_path.mkdir(parents=True, exist_ok=True)
    
    # Determine shell command
    if sys.platform == "win32":
        shell_cmd = ["cmd.exe"]
    else:
        shell_cmd = ["/bin/bash", "--norc", "--noprofile"]
    
    # Create subprocess with pipes
    proc = await asyncio.create_subprocess_exec(
        *shell_cmd,
        stdin=subprocess.PIPE,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        cwd=str(workspace_path),
        env={**os.environ, "TERM": "xterm-256color"}
    )
    
    # Forward stdout/stderr to websocket
    async def read_stream(stream, ws):
        while True:
            line = await stream.readline()
            if not line:
                break
            await ws.send_text(line.decode('utf-8', errors='replace'))
    
    out_task = asyncio.create_task(read_stream(proc.stdout, websocket))
    err_task = asyncio.create_task(read_stream(proc.stderr, websocket))
    
    # Send a welcome message
    await websocket.send_text(f"\x1b[32mTerminal ready in {workspace_path}\x1b[0m\r\n")
    
    try:
        while True:
            data = await websocket.receive_text()
            if data == "__CLEAR__":
                # Clear terminal (send ANSI clear)
                await websocket.send_text("\x1b[2J\x1b[H")
                continue
            # Send command to stdin
            proc.stdin.write((data + "\n").encode())
            await proc.stdin.drain()
    except WebSocketDisconnect:
        pass
    finally:
        proc.terminate()
        await proc.wait()
        out_task.cancel()
        err_task.cancel()
import subprocess
import os
import re
from pydantic import BaseModel

class NetlifyDeployRequest(BaseModel):
    workspace_id: int
    netlify_token: str = ""  # optional, can use global env

@app.post("/api/deploy-netlify")
async def deploy_to_netlify(req: NetlifyDeployRequest):
    repo_path = get_workspace_path(req.workspace_id)
    if not repo_path.exists():
        raise HTTPException(status_code=404, detail="No project found")
    
    # Create netlify.toml if not exists (static site configuration)
    netlify_toml = repo_path / "netlify.toml"
    if not netlify_toml.exists():
        netlify_toml.write_text("""
[build]
  publish = "."
  
[[redirects]]
  from = "/*"
  to = "/index.html"
  status = 200
""")
    
    # Run netlify deploy (requires netlify-cli installed globally)
    env = os.environ.copy()
    if req.netlify_token:
        env["NETLIFY_AUTH_TOKEN"] = req.netlify_token
    try:
        result = subprocess.run(
            ["npx", "netlify", "deploy", "--prod", "--dir", ".", "--message", "VibeCoder deployment"],
            capture_output=True,
            text=True,
            cwd=str(repo_path),
            env=env,
            timeout=60
        )
        if result.returncode != 0:
            raise HTTPException(status_code=500, detail=result.stderr)
        # Extract URL from output
        match = re.search(r'https://[-\w]+\.netlify\.app', result.stdout)
        url = match.group(0) if match else "deployed but URL not found"
        return {"status": "deployed", "url": url}
    except subprocess.TimeoutExpired:
        raise HTTPException(status_code=500, detail="Deployment timed out")
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))
