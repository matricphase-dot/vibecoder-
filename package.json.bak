{
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "lucide-react": "^1.7.0",
    "ws": "^8.20.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0",
    "y-monaco": "^0.1.6",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.30"
  },
  "name": "vibe-coding-platform",
  "version": "1.0.0",
  "description": "",
  "main": "yjs-server.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  }
}
"main": "electron-main.js",
"scripts": {
  "start": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
  "dev:frontend": "cd frontend && npm run dev",
  "dev:backend": "cd backend && python -m uvicorn src.main:app --reload --host 127.0.0.1 --port 8000",
  "electron": "electron .",
  "build": "npm run build:frontend && electron-builder",
  "build:frontend": "cd frontend && npm run build"
},
"build": {
  "appId": "com.vibecoder.app",
  "productName": "VibeCoder",
  "directories": {
    "output": "dist"
  },
  "files": [
    "electron-main.js",
    "preload.js",
    "backend/**/*",
    "frontend/dist/**/*"
  ],
  "win": {
    "target": "nsis",
    "icon": "assets/icon.ico"
  },
  "mac": {
    "target": "dmg",
    "icon": "assets/icon.icns"
  },
  "linux": {
    "target": "AppImage",
    "icon": "assets/icon.png"
  }
}