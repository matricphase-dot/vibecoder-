{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd frontend && npm install",
  "devCommand": "cd frontend && npm run dev",
  "framework": "vite",
  "routes": [
    { "src": "/api/(.*)", "dest": "https://web-production-6555d.up.railway.app/api/$1" },
    { "src": "/ws/(.*)", "dest": "wss://web-production-6555d.up.railway.app/ws/$1" },
    { "src": "/(.*)", "dest": "/frontend/dist/index.html" }
  ],
  "env": {
    "VITE_BACKEND_URL": "https://web-production-6555d.up.railway.app"
  }
}
